{
  "agents": {
    "defaults": {
      "workspace": "./nexus/workspace",
      "model": {
        "primary": "google/gemini-2.5-flash"
      },
      "models": {
        "google/gemini-2.5-flash": {
          "alias": "gemini-flash"
        }
      },
      "thinkingDefault": "medium",
      "timeoutSeconds": 600,
      "skills": [
        "recon-scan",
        "web-vuln-scan",
        "osint-gather",
        "password-crack",
        "exploit-ops",
        "network-ops",
        "social-engineer",
        "wireless-audit",
        "post-exploit",
        "log-analyzer",
        "container-security",
        "threat-intel",
        "forensic-analysis",
        "network-monitor",
        "report-generator"
      ],
      "sandbox": {
        "mode": "all",
        "backend": "ssh",
        "scope": "agent",
        "workspaceAccess": "none",
        "ssh": {
          "target": "nexus@127.0.0.1:2222",
          "workspaceRoot": "/tmp/openclaw-sandboxes",
          "identityFile": "./nexus/config/nexus_key",
          "strictHostKeyChecking": false,
          "updateHostKeys": false
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "NEXUS Kali Operator"
      },
      {
        "id": "ubuntu-worker",
        "name": "NEXUS Ubuntu Worker",
        "sandbox": {
          "mode": "all",
          "backend": "ssh",
          "scope": "agent",
          "workspaceAccess": "none",
          "ssh": {
            "target": "nexus@127.0.0.1:2223",
            "workspaceRoot": "/tmp/openclaw-sandboxes",
            "identityFile": "./nexus/config/nexus_key",
            "strictHostKeyChecking": false,
            "updateHostKeys": false
          }
        }
      }
    ]
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./nexus/skills"
      ],
      "watch": true
    }
  },
  "tools": {
    "allow": [
      "exec",
      "process",
      "read",
      "write",
      "edit",
      "apply_patch"
    ],
    "deny": [
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway"
    ],
    "exec": {
      "host": "auto",
      "security": "full",
      "ask": "off"
    },
    "sandbox": {
      "tools": {
        "allow": [
          "exec",
          "process",
          "read",
          "write",
          "edit",
          "apply_patch"
        ],
        "deny": [
          "browser",
          "canvas",
          "nodes",
          "cron",
          "gateway"
        ]
      }
    }
  },
  "gateway": {
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18789",
        "http://localhost:18789"
      ]
    },
    "auth": {
      "mode": "none"
    },
    "tailscale": {}
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": false
      },
      "google": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.20",
    "lastTouchedAt": "2026-05-01T06:18:50.861Z"
  }
}
